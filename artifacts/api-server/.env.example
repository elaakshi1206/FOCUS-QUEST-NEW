# ──────────────────────────────────────────────
# @workspace/api-server — Environment Variables
# ──────────────────────────────────────────────

# Required: PostgreSQL connection string
# Get a free one from https://neon.tech or https://supabase.com
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/focusquest

# Server port
PORT=3001

# Optional: CORS allowed origins (comma separated)
CORS_ORIGIN=http://localhost:5173
